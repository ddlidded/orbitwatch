# OrbitWatch environment configuration
# Copy to .env and adjust for your deployment.

# Backend
# NOTE: If you use docker-compose.easypanel.yml (or the Docker Compose stacks), do
# NOT paste these DATABASE_URL/REDIS_URL values into Easypanel. The compose file
# builds the URLs automatically from the internal postgres/redis services.
ORBITWATCH_ENV=development
DATABASE_URL=postgresql+psycopg2://orbitwatch:orbitwatch@localhost:5432/orbitwatch
REDIS_URL=redis://localhost:6379/0
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_TTL_MINUTES=30
REFRESH_TOKEN_TTL_DAYS=7
MAX_SESSION_LIFETIME_DAYS=30
INACTIVITY_TIMEOUT_MINUTES=60

# CORS origins for the backend (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost,https://localhost

# Object storage (MinIO in local docker)
# NOTE: For Docker Compose/Easypanel deployments, S3_ENDPOINT is set to the
# internal minio service (http://minio:9000) automatically.
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=orbitwatch
S3_SECURE=false
S3_REGION=us-east-1

# Frontend dev proxy (used by docker-compose; defaults to localhost outside docker)
VITE_API_PROXY_TARGET=http://localhost:8000
VITE_WS_PROXY_TARGET=ws://localhost:8000

# Agent
AGENT_BACKEND_URL=http://localhost:8000/api/v1
AGENT_BOOTSTRAP_TOKEN=set-via-backend
AGENT_INSTRUMENT_SERIAL=IQLAAEGAAPFADBMK
AGENT_INSTRUMENT_NAME="Exploris 480"
AGENT_INSTRUMENT_MODEL="Orbitrap Exploris 480"
